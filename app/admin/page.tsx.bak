"use client";

import { useState, useEffect, useCallback, useRef } from "react";

// еӣҫзүҮдёҠдј з»„д»¶ - ж”ҜжҢҒжӢ–жӢҪ + йў„и§Ҳ + URLиҫ“е…Ҙ
function ImageUploader({ value, onChange, label }: { value: string; onChange: (url: string) => void; label: string }) {
  const [uploading, setUploading] = useState(false);
  const [dragOver, setDragOver] = useState(false);
  const inputRef = useRef<HTMLInputElement>(null);

  async function uploadFile(file: File) {
    setUploading(true);
    const fd = new FormData();
    fd.append("file", file);
    try {
      const res = await fetch("/api/upload", { method: "POST", body: fd });
      const data = await res.json();
      if (data.url) {
        onChange(data.url);
      }
    } catch (e) {
      console.error("Upload failed", e);
    }
    setUploading(false);
  }

  function handleDrop(e: React.DragEvent) {
    e.preventDefault();
    setDragOver(false);
    const file = e.dataTransfer.files[0];
    if (file && file.type.startsWith("image/")) {
      uploadFile(file);
    }
  }

  function handleFileChange(e: React.ChangeEvent<HTMLInputElement>) {
    const file = e.target.files?.[0];
    if (file) uploadFile(file);
  }

  return (
    <div className="space-y-2">
      <label className="block text-sm font-medium text-gray-700">{label}</label>
      <div
        className={`relative border-2 border-dashed rounded-lg p-4 transition-colors cursor-pointer ${dragOver ? "border-[#C9A96E] bg-amber-50" : "border-gray-300 hover:border-[#C9A96E]"}`}
        onDragOver={(e) => { e.preventDefault(); setDragOver(true); }}
        onDragLeave={() => setDragOver(false)}
        onDrop={handleDrop}
        onClick={() => inputRef.current?.click()}
      >
        {uploading ? (
          <div className="py-8 text-center">
            <div className="animate-spin h-8 w-8 border-2 border-[#C9A96E] border-t-transparent rounded-full mx-auto mb-2" />
            <p className="text-sm text-gray-500">дёҠдј дё?..</p>
          </div>
        ) : value ? (
          <div className="relative">
            <img src={value} alt="" className="max-h-48 mx-auto object-contain rounded" />
            <div className="absolute top-2 right-2 flex gap-2">
              <button onClick={(e) => { e.stopPropagation(); inputRef.current?.click(); }} className="bg-white/90 text-xs px-2 py-1 rounded shadow hover:bg-white">жӣҙжҚў</button>
              <button onClick={(e) => { e.stopPropagation(); onChange(""); }} className="bg-red-500 text-white text-xs px-2 py-1 rounded shadow hover:bg-red-600">еҲ йҷӨ</button>
            </div>
          </div>
        ) : (
          <div className="py-8 text-center">
            <div className="text-4xl mb-2">рҹ“Ғ</div>
            <p className="text-sm text-gray-500">жӢ–жӢҪеӣҫзүҮеҲ°иҝҷйҮҢпјҢжҲ–зӮ№еҮ»йҖүжӢ©ж–Үд»¶</p>
            <p className="text-xs text-gray-400 mt-1">ж”ҜжҢҒ JPG, PNG, WebP иҮӘеҠЁиҪ¬дёә WebP ж јејҸ</p>
          </div>
        )}
        <input ref={inputRef} type="file" accept="image/*" className="hidden" onChange={handleFileChange} />
      </div>
      {/* URLиҫ“е…ҘжЎ?*/}
      <input type="text" value={value} onChange={(e) => onChange(e.target.value)} placeholder="жҲ–зӣҙжҺҘзІҳиҙҙеӣҫзүҮURL" className="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#C9A96E] focus:border-transparent" />
    </div>
  );
}

// жү№йҮҸеҜје…Ҙз»„д»¶ - д»Һеҫ®иҙӯзӣёеҶҢExcelж–Үд»¶еҜје…Ҙ
function BulkImport({ onImportComplete }: { onImportComplete: () => void }) {
  const [importing, setImporting] = useState(false);
  const [progress, setProgress] = useState(0);
  const [result, setResult] = useState<any>(null);
  const [error, setError] = useState("");
  const inputRef = useRef<HTMLInputElement>(null);

  const handleImport = async (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0];
    if (!file) return;

    setImporting(false);
  };

  return (
    <div className="bg-gray-50 rounded-lg p-6 mb-8">
      <h3 className="text-lg font-medium mb-4">жү№йҮҸеҜје…Ҙдә§е“Ғ</h3>
      
      <div className="flex items-center gap-4">
        <input
          ref={inputRef}
          type="file"
          accept=".xlsx"
          onChange={handleImport}
          disabled={importing}
          className="hidden"
        />
        
        <button
          onClick={() => inputRef.current?.click()}
          disabled={importing}
          className="px-4 py-2 bg-[#1A1A1A] text-white rounded-lg hover:bg-[#333] disabled:opacity-50 flex items-center gap-2"
        >
          <span>рҹ“Ҙ</span>
          {importing ? 'еҜје…Ҙдё?..' : 'йҖүжӢ©еҫ®иҙӯзӣёеҶҢExcelж–Үд»¶'}
        </button>
        
        {importing && (
          <div className="flex items-center gap-2">
            <div className="animate-spin h-5 w-5 border-2 border-[#C9A96E] border-t-transparent rounded-full"></div>
            <span className="text-sm text-gray-500">{progress}%</span>
          </div>
        )}
      </div>
      
      <p className="text-sm text-gray-500 mt-2">
        д»Һеҫ®иҙӯзӣёеҶҢеҜјеҮәзҡ„Excelж–Үд»¶пјҢж”ҜжҢҒжү№йҮҸеҜје…Ҙдә§е“ҒеӣҫзүҮе’ҢжҸҸиҝ°
      </p>

      {result && (
        <div className="mt-4 p-4 bg-green-50 rounded-lg border border-green-200">
          <p className="text-green-700 font-medium">вң?еҜје…ҘжҲҗеҠҹпј?/p>
          <p className="text-sm text-green-600 mt-1">
            е·ІеҜје…?{result.imported} дёӘдә§е“ҒпјҢе…?{result.total} дёӘдә§е“?
          </p>
          {result.errors && result.errors.length > 0 && (
            <p className="text-sm text-yellow-600 mt-1">
              {result.errors.length} дёӘдә§е“ҒеҜје…ҘеӨұиҙ?
            </p>
          )}
        </div>
      )}

      {error && (
        <div className="mt-4 p-4 bg-red-50 rounded-lg border border-red-200">
          <p className="text-red-700">еҜје…ҘеӨұиҙҘ: {error}</p>
        </div>
      )}
    </div>
  );
}

interface Spec { id: string; color: string; size: string; image: string; stock: number; }
interface Product { id: string; name: string; nameCn?: string; category: string; categoryName: string; price: number; currency: string; description: string; descriptionCn?: string; mainImage: string; specs: Spec[]; detailImages: string[]; }
interface SiteImages { hero: { image: string; title: string; }; womenswear: { main: string; secondary: string; }; menswear: { main: string; secondary: string; }; journal: { post1: string; post2: string; post3: string; }; }ing(true);
    setError("");
    setResult(null);
    setProgress(0);

    try {
      // еҠЁжҖҒеҠ иҪҪSheetJS
      let XLSX = (window as any).XLSX;
      if (!XLSX) {
        // еҠ иҪҪSheetJSеә?
        await new Promise<void>((resolve, reject) => {
          const script = document.createElement('script');
          script.src = 'https://cdn.sheetjs.com/xlsx-0.20.1/package/dist/xlsx.full.min.js';
          script.onload = () => resolve();
          script.onerror = () => reject(new Error('Failed to load Excel library'));
          document.head.appendChild(script);
        });
        XLSX = (window as any).XLSX;
      }
      
      // иҜ»еҸ–Excelж–Үд»¶
      const arrayBuffer = await file.arrayBuffer();
      const workbook = XLSX.read(arrayBuffer, { type: 'array', cellImages: true });
      const sheetName = workbook.SheetNames[0];
      const worksheet = workbook.Sheets[sheetName];
      
      // иҪ¬жҚўдёәJSON
      const jsonData = XLSX.utils.sheet_to_json(worksheet, { header: 1 });
      
      // жҸҗеҸ–еӣҫзүҮ
      const images: Map<number, string> = new Map();
      if ((worksheet as any)._images) {
        for (let i = 0; i < (worksheet as any)._images.length; i++) {
          const img = (worksheet as any)._images[i];
          if (img.data) {
            const base64 = btoa(String.fromCharCode.apply(null, new Uint8Array(img.data)));
            images.set(i, base64);
          }
        }
      }

      // еӨ„зҗҶдә§е“Ғж•°жҚ®
      const products: any[] = [];
      const headers = jsonData[0] as string[];
      
      // жүҫеҲ°е…ій”®еҲ—зҡ„зҙўеј•
      const nameIdx = headers.indexOf('е•Ҷе“ҒеҗҚз§°/жҸҸиҝ°');
      const tagsIdx = headers.indexOf('ж Үзӯҫ');
      
      for (let i = 1; i < jsonData.length; i++) {
        const row = jsonData[i] as any[];
        if (!row || row.length === 0) continue;
        
        const name = row[nameIdx] || '';
        const tags = row[tagsIdx] || '';
        
        // жҸҗеҸ–е“ҒзүҢ
        let brand = 'NOREVA';
        if (tags.includes('Ferragamo') || name.includes('иҸІжӢүж јж…•')) brand = 'Ferragamo';
        if (tags.includes('Gucci') || name.includes('еҸӨй©°')) brand = 'Gucci';
        
        // жҸҗеҸ–зұ»еһӢ
        let type = 'Classic';
        if (name.includes('иҮӘеҠЁ')) type = 'Automatic Buckle';
        if (name.includes('жҢӮжүЈ')) type = 'Pin Buckle';
        
        // жҸҗеҸ–йўңиүІ
        let color = 'Brown';
        if (name.includes('йҮ‘жүЈ') || name.includes('Gold')) color = 'Gold';
        if (name.includes('й“¶жүЈ') || name.includes('Silver')) color = 'Silver';
        if (name.includes('й»?)) color = 'Black';
        
        // дә§е“ҒеҗҚз§°
        const productName = `${brand} ${type} Belt - ${color}`;
        
        // иҺ·еҸ–еӣҫзүҮ
        const imgIndex = i - 1; // Excelд»Һз¬¬2иЎҢејҖе§ӢеҜ№еә”з¬¬1еј еӣҫзү?
        const imageBase64 = images.get(imgIndex) || null;
        
        products.push({
          name: productName,
          nameCn: String(name).substring(0, 100),
          category: 'jewelry',
          categoryName: 'Belts',
          categoryNameCn: 'зҡ®еёҰ',
          color: color,
          colorCn: color === 'Brown' ? 'жЈ•иүІ' : color === 'Gold' ? 'йҮ‘иүІ' : color === 'Silver' ? 'й“¶иүІ' : 'й»‘иүІ',
          price: 0,
          currency: 'USD',
          description: String(name),
          descriptionCn: String(name),
          imageBase64: imageBase64,
          stock: 999,
        });
      }

      setProgress(20);
      
      // еҸ‘йҖҒеҲ°жңҚеҠЎеҷ?
      const res = await fetch('/api/bulk-import', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ products }),
      });

      setProgress(80);
      
      const data = await res.json();
      
      setProgress(100);
      
      if (data.success) {
        setResult(data);
        onImportComplete();
      } else {
        setError(data.error || 'Import failed');
      }
    } catch (err: any) {
      setError(err.message || 'Import failed');
    }

    setImporting(false);
  };

  return (
    <div className="bg-gray-50 rounded-lg p-6 mb-8">
      <h3 className="text-lg font-medium mb-4">жү№йҮҸеҜје…Ҙдә§е“Ғ</h3>
      
      <div className="flex items-center gap-4">
        <input
          ref={inputRef}
          type="file"
          accept=".xlsx"
          onChange={handleImport}
          disabled={importing}
          className="hidden"
        />
        
        <button
          onClick={() => inputRef.current?.click()}
          disabled={importing}
          className="px-4 py-2 bg-[#1A1A1A] text-white rounded-lg hover:bg-[#333] disabled:opacity-50 flex items-center gap-2"
        >
          <span>рҹ“Ҙ</span>
          {importing ? 'еҜје…Ҙдё?..' : 'йҖүжӢ©еҫ®иҙӯзӣёеҶҢExcelж–Үд»¶'}
        </button>
        
        {importing && (
          <div className="flex items-center gap-2">
            <div className="animate-spin h-5 w-5 border-2 border-[#C9A96E] border-t-transparent rounded-full"></div>
            <span className="text-sm text-gray-500">{progress}%</span>
          </div>
        )}
      </div>
      
      <p className="text-sm text-gray-500 mt-2">
        д»Һеҫ®иҙӯзӣёеҶҢеҜјеҮәзҡ„Excelж–Үд»¶пјҢж”ҜжҢҒжү№йҮҸеҜје…Ҙдә§е“ҒеӣҫзүҮе’ҢжҸҸиҝ°
      </p>

      {result && (
        <div className="mt-4 p-4 bg-green-50 rounded-lg border border-green-200">
          <p className="text-green-700 font-medium">вң?еҜје…ҘжҲҗеҠҹпј?/p>
          <p className="text-sm text-green-600 mt-1">
            е·ІеҜје…?{result.imported} дёӘдә§е“ҒпјҢе…?{result.total} дёӘдә§е“?
          </p>
          {result.errors && result.errors.length > 0 && (
            <p className="text-sm text-yellow-600 mt-1">
              {result.errors.length} дёӘдә§е“ҒеҜје…ҘеӨұиҙ?
            </p>
          )}
        </div>
      )}

      {error && (
        <div className="mt-4 p-4 bg-red-50 rounded-lg border border-red-200">
          <p className="text-red-700">еҜје…ҘеӨұиҙҘ: {error}</p>
        </div>
      )}
    </div>
  );
}

